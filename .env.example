# ============================================================
# MedQLoRA — Environment Variables Template
# Copy to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================

# ── HuggingFace ─────────────────────────────────────────────
# Required for: downloading gated models (Llama 3.1), pushing adapters to Hub
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Weights & Biases ─────────────────────────────────────────
# Required for: training loss curves, sample generation logging
# Get yours at: https://wandb.ai/settings
# If not set, training will log locally to training/training_log.jsonl
WANDB_API_KEY=your_wandb_api_key_here

# ── Optional overrides ───────────────────────────────────────
# Override the W&B project name (default: medqlora)
# WANDB_PROJECT=medqlora

# Override the HF Hub repo to push adapters to
# HUB_MODEL_ID=your-username/medqlora-llama-3.1-8b
