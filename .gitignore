# ── Model weights and adapters ───────────────────────────────
# Exclude raw training-output checkpoints (~640 MB, every 50 iters)
# but KEEP the curated deployed adapter so the HF Space can serve it.
adapters/
adapters_techmojo/
*.bin
*.pt
*.pth
# Catch any other safetensors but explicitly allow the deployed adapters:
#  - adapters_techmojo_best/         (MLX layout, served on Apple Silicon)
#  - adapters_techmojo_best_peft/    (PEFT layout, served on Linux/Spaces)
*.safetensors
!adapters_techmojo_best/adapters.safetensors
!adapters_techmojo_best_peft/adapter_model.safetensors

# ── Evaluation results ────────────────────────────────────────
evaluation/baseline_scores.json
evaluation/finetuned_scores.json

# ── Training logs ─────────────────────────────────────────────
training/training_log.jsonl

